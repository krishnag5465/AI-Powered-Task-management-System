    "# Age Group distribution.\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Example dataset (agar tumhare paas already df hai to ye remove kar do)\n",
    "data = {\n",
    "    'age': [8,15,22,34,45,52,63,70,28,18,12,40,55,60]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "# Create age groups\n",
    "bins = [5, 12, 19, 35, 55, 75]\n",
    "labels = [\n",
    "    'Kids_5_12',\n",
    "    'Teens_13_19',\n",
    "    'YoungAdults_20_35',\n",
    "    'MiddleAge_36_55',\n",
    "    'Seniors_56_75'\n",
    "]\n",
    "\n",
    "df['age_group'] = pd.cut(df['age'], bins=bins, labels=labels)\n",
    "\n",
    "# Order of bars\n",
    "age_order = [\n",
    "    'Kids_5_12',\n",
    "    'Teens_13_19',\n",
    "    'YoungAdults_20_35',\n",
    "    'MiddleAge_36_55',\n",
    "    'Seniors_56_75'\n",
    "]\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "\n",
    "counts = df['age_group'].value_counts().reindex(age_order, fill_value=0)\n",
    "\n",
    "counts.plot(kind='bar', color='#4C72B0', edgecolor='white', width=0.6)\n",
    "\n",
    "plt.title(\"Age Group Distribution\")\n",
    "plt.xlabel(\"Age Group\")\n",
    "plt.ylabel(\"Number of Users\")\n",
    "\n",
    "plt.xticks(rotation=30, ha='right')\n",
    "plt.tight_layout()\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n"
   ]
